# Optional overrides. Defaults load MiniMax from:
#   ~/.config/ai-providers/env.local  (MINIMAX_API_KEY / MINIMAX_TOKEN_PLAN_KEY / MINIMAX_MODEL)
# You usually do NOT need a local .env if that file already exists.

# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M3
# STAGEHAND_MODEL=MiniMax-M3

# HEADLESS=false
# AUTO_APPROVE=1
# STAGEHAND_VERBOSE=1
# CHROME_PATH=
