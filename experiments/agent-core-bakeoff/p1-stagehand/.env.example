# Copy to .env (never commit .env)
# Prefer a mid-tier model — bake-off rule: simple/mid models must work.

# OpenAI-compatible or provider keys Stagehand/ai-sdk understands
OPENAI_API_KEY=
# Optional OpenAI-compatible base (e.g. MiniMax / proxy)
# OPENAI_BASE_URL=https://api.minimaxi.com/v1

# Model id for act/extract (mid-tier default intent)
STAGEHAND_MODEL=openai/gpt-4o-mini

# Local Chrome (macOS defaults used if empty)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# headless=false so you can watch approval
HEADLESS=false
